# ============================================================
#  eWatch — Environment Variables
#  Copy this file to .env and fill in your real values
# ============================================================

PORT=3000
NODE_ENV=production

# ── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=ewatch_db

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_64chars_minimum
JWT_EXPIRES_IN=7d

# ── Gmail SMTP (get App Password from Google Account settings) 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16char_app_password

MAIL_FROM="eWatch Barangay Bancao-Bancao <noreply@ewatch.ph>"

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
